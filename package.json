{
  "name": "flight-club",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisreddington/flight-club.git"
  },
  "author": "Chris Reddington",
  "homepage": "https://github.com/chrisreddington/flight-club",
  "bugs": {
    "url": "https://github.com/chrisreddington/flight-club/issues"
  },
  "scripts": {
    "dev": "npm run aspire:run",
    "dev:web-only": "rm -rf .next && next dev",
    "dev:worker": "node scripts/dev-worker.mjs",
    "start:worker": "node dist-worker/bootstrap.mjs",
    "build:worker": "node scripts/build-worker.mjs",
    "storage:migrate": "node --conditions=react-server --import tsx scripts/storage-migrate.mts",
    "dev:web-worker": "COPILOT_WORKER_URL=http://localhost:3001 COPILOT_WORKER_SECRET=local-dev-worker-secret npm run dev:web-only",
    "build": "next build",
    "start": "next start",
    "dashboard": "aspire dashboard run --allow-anonymous",
    "aspire:run": "aspire run",
    "aspire:start": "aspire run",
    "aspire:mcp": "aspire agent mcp --dashboard-url http://localhost:18888",
    "aspire:deploy": "aspire deploy",
    "aspire:destroy": "aspire destroy",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:fast": "npm run lint && npm run lint:md && npm run format:check",
    "verify": "npm run lint && npm run format:check && npx tsc --noEmit && npm test && npm run check:guardrails && npm run build",
    "prepare": "husky",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "debt:check": "npm run debt:unused && npm run debt:exports && npm run debt:deps && npm run debt:circular",
    "debt:unused": "knip --exclude duplicates",
    "debt:exports": "ts-prune --project tsconfig.json",
    "debt:deps": "depcheck --ignores='@types/*,eslint-*,@eslint/*,vitest,@vitest/*,tsx'",
    "debt:circular": "madge --circular --extensions ts,tsx src/",
    "check:sizes": "node scripts/check-file-sizes.mjs",
    "check:test-boundaries": "node scripts/check-test-boundaries.mjs",
    "check:cache-key-scope": "node scripts/check-cache-key-scope.mjs",
    "check:server-fetch-tenancy": "node scripts/check-server-fetch-tenancy.mjs",
    "check:server-action-guards": "node scripts/check-server-action-guards.mjs",
    "check:otel-emitted": "node scripts/check-otel-emitted.mjs",
    "check:copilot-sdk-boundary": "node scripts/check-copilot-sdk-boundary.mjs",
    "check:web-image": "node scripts/check-web-image-copilot-free.mjs",
    "check:web-image-local": "SKIP_WEB_IMAGE_CHECK=1 node scripts/check-web-image-copilot-free.mjs",
    "check:worker-next-free": "node scripts/check-worker-next-free.mjs",
    "check:guardrails": "npm run check:sizes && npm run check:test-boundaries && npm run check:cache-key-scope && npm run check:server-fetch-tenancy && npm run check:server-action-guards && npm run check:copilot-sdk-boundary && npm run check:worker-next-free && npm run check:web-image-local && npm run debt:unused",
    "maintainability:check": "npm run debt:unused -- --reporter compact && npm run debt:deps && npm run debt:circular && npm run check:sizes",
    "aspire:lint": "eslint apphost.mts",
    "aspire:build": "tsc -p tsconfig.apphost.json",
    "aspire:dev": "tsc --watch -p tsconfig.apphost.json",
    "run": "npm run aspire:run",
    "mcp": "npm run aspire:mcp",
    "deploy": "npm run aspire:deploy",
    "destroy": "npm run aspire:destroy"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,yml,yaml,css}": "prettier --write",
    "*.md": "markdownlint-cli2 --fix"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-keys": "^4.10.2",
    "@github/copilot-sdk": "^1.0.1",
    "@hono/node-server": "^2.0.5",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/context-zone": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-document-load": "^0.64.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-undici": "^0.29.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@primer/css": "^22.3.0",
    "@primer/octicons-react": "^19.28.1",
    "@primer/react": "^38.28.0",
    "@tanstack/react-query": "5.101.0",
    "@vercel/otel": "^2.1.3",
    "eventsource-parser": "^3.1.0",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "octokit": "^5.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "client-only": "^0.0.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.0.17",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "ts-prune": "^0.10.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.0.18"
  },
  "description": "AI-powered developer growth companion - personalized coding challenges and tips based on GitHub activity",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
