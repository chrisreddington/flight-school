# Auth.js v5 (multi-tenant GitHub App OAuth)
AUTH_SECRET=                  # openssl rand -base64 32
AUTH_GITHUB_ID=               # GitHub App client id
AUTH_GITHUB_SECRET=           # GitHub App client secret
AUTH_TRUST_HOST=true          # required when ACA is behind a proxy

# Legacy single-tenant fallback (still used until P2 Octokit refactor lands)
# GITHUB_TOKEN=

# Set to 'true' in Azure Container Apps deployments to disable the gh CLI auth fallback.
# ACA_DEPLOYMENT=

# AI provider configuration (optional)
# GITHUB_MODELS_ENABLED=true
# GITHUB_MODELS_MODEL=gpt-4o-mini
# AZURE_AI_ENDPOINT=
# AZURE_AI_KEY=
# AZURE_AI_DEPLOYMENT=
